\newlabel{fig:ladder}{{7}{24}{Six-mode precision ladder (FP/DW/TW $\times $ FP32-base/FP64-base) on $16^4$. Each precision sets a distinct residual floor while the descent rate is shared---precision sets the floor, the spectrum sets the rate}{figure.7}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.5.3}Reach, not rate: recursive versus true residual}{24}{subsubsection.3.5.3}\protected@file@percent }
