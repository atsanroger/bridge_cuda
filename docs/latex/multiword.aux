\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Even-odd (checkerboard) decomposition of the lattice. Blue sites (even: $\DOTSB \sum@ \slimits@ _\mu x_\mu $ even) and orange sites (odd) form two sublattices. Nearest-neighbour hopping only connects even $\leftrightarrow $ odd sites, giving the block off-diagonal structure~\textup  {\hbox {\mathsurround \z@ \normalfont  (\ignorespaces \ref  {eq:block_D}\unskip \@@italiccorr )}}. Each sublattice contains $V/2$ sites, and the Schur-complement system~\textup  {\hbox {\mathsurround \z@ \normalfont  (\ignorespaces \ref  {eq:schur}\unskip \@@italiccorr )}} acts only on the even sublattice.}}{7}{figure.3}\protected@file@percent }
\newlabel{fig:checkerboard}{{3}{7}{Even-odd (checkerboard) decomposition of the lattice. Blue sites (even: $\sum _\mu x_\mu $ even) and orange sites (odd) form two sublattices. Nearest-neighbour hopping only connects even $\leftrightarrow $ odd sites, giving the block off-diagonal structure~\eqref {eq:block_D}. Each sublattice contains $V/2$ sites, and the Schur-complement system~\eqref {eq:schur} acts only on the even sublattice}{figure.3}{}}
